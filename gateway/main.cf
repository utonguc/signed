myhostname = gateway.signature.local
inet_interfaces = all
inet_protocols = ipv4

# Accept mail from anywhere (Exchange sends to us)
mynetworks = 0.0.0.0/0

# Pipe all inbound mail through the signature processor
content_filter = signature-filter:dummy

# Prevent address-mapping loops after re-injection
receive_override_options = no_address_mappings
